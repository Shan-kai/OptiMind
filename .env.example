# OptiMind environment configuration (copy to .env and fill in your values)

# General
OPTI_MIND_ENV=local
OPTI_MIND_LOG_LEVEL=INFO
# OPTI_MIND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# OPTI_MIND_UPLOAD_TTL_SECONDS=86400

# LLM configuration
# Supported providers: openai, kimi, ollama, anthropic
OPTI_MIND_LLM_PROVIDER=openai
OPTI_MIND_LLM_MODEL=moonshot-v1-8k
OPTI_MIND_LLM_API_KEY=your-api-key

# Base URL depends on provider:
# - Kimi (OpenAI-compatible): https://api.moonshot.cn/v1
# - Kimi (Anthropic-compatible / coding): https://api.kimi.com/coding/
# - OpenAI: https://api.openai.com/v1
# - Ollama: http://localhost:11434
# - Anthropic: https://api.anthropic.com
OPTI_MIND_LLM_BASE_URL=https://api.moonshot.cn/v1

# Set to true to use LLM for schema interpretation
OPTI_MIND_LLM_SCHEMA_INTERPRETER=true

# Set to true to use LLM for model generation (fallback to deterministic IRGenerator)
OPTI_MIND_LLM_MODEL_GENERATOR=true

# Set to true to use LLM for decision analysis (fallback to deterministic report)
OPTI_MIND_LLM_DECISION_ANALYZER=true

# Set to true to let the LLM answer post-solution questions via tools
OPTI_MIND_LLM_DECISION_ANALYZER_AGENT=true

# Agentic conversation layer
# Set to true to use the single LLM orchestrator that controls mapping + parameters + pipeline
OPTI_MIND_LLM_ORCHESTRATOR_AGENT=true

# Optional: max tool turns per orchestrator loop (default 15)
# OPTI_MIND_LLM_ORCHESTRATOR_MAX_TOOL_TURNS=15

# Optional: sample rows passed to the LLM schema interpreter (default 5)
# OPTI_MIND_LLM_ORCHESTRATOR_SAMPLE_ROWS=5

# Session event logs directory
# OPTI_MIND_SESSION_LOG_DIR=sessions

# Persist LangGraph checkpoints to SQLite so sessions survive server reloads
# OPTI_MIND_PERSIST_CHECKPOINTS=true

# Solver configuration
OPTI_MIND_SOLVER_BACKEND=mock
